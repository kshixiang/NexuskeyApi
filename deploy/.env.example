# Simple mode only (scripts/deploy.sh install --simple). Production: .env.prod.example
# Deploy directory priority: --dir > DEPLOY_DIR env > /www/wwwroot/nexuskey-api

# Required — session signing (generate with: openssl rand -hex 32)
SESSION_SECRET=change_me_to_a_long_random_string

# Host port mapped to container 3000
HTTP_PORT=3000

# Timezone
TZ=Asia/Shanghai

# Optional toggles
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true

# Do not set SQL_DSN for simple mode (SQLite is stored under ./data).
