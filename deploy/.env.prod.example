# Production deploy .env (scripts/deploy.sh install — default mode)
# Copy to deploy directory as .env; install generates secrets when placeholders are present.
# Priority: --dir > DEPLOY_DIR > /www/wwwroot/nexuskey-api

# --- Application (required) ---
SESSION_SECRET=change_me_to_a_long_random_string
CRYPTO_SECRET=change_me_to_a_long_random_string

# Host port mapped to new-api container 3000
HTTP_PORT=3000

TZ=Asia/Shanghai
NODE_NAME=new-api-node-1
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true

# --- PostgreSQL (required for prod) ---
POSTGRES_USER=root
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=new-api

# --- Redis (required for prod) ---
REDIS_PASSWORD=change_me_redis_password

# SQL_DSN and REDIS_CONN_STRING are built by docker-compose.prod.yml — do not set here.
